{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "manuals-cache",
      "urls": ["/v1/manuals", "/v1/manuals/*", "/v1/machines"],
      "cacheConfig": {
        "maxSize": 500,
        "maxAge": "14d",
        "timeout": "10s",
        "strategy": "performance"
      }
    },
    {
      "name": "live",
      "urls": ["/v1/chat/**", "/v1/tickets/**", "/v1/maintenance-log/**", "/v1/alerts/**"],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "5s",
        "strategy": "freshness"
      }
    }
  ]
}
